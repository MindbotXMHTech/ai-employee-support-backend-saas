# All three must be from the same Supabase project (local: run `npx supabase status` and copy URL + keys together).
# If you also use `.env.local`: Next.js merges `.env` + `.env.local` in dev; duplicate keys are overridden by `.env.local`.
# Put secrets only in `.env.local` if you like, but do not leave stale NEXT_PUBLIC_SUPABASE_* / SUPABASE_* there.

# Platform admin first-run (optional beyond trusted network):
#   npm run secrets:platform-setup → set PLATFORM_SETUP_SECRET; same value as Bootstrap token on /setup/platform-admin
PLATFORM_SETUP_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
APP_URL=http://localhost:3000
DEFAULT_TRIAL_DAYS=35
DEFAULT_TRIAL_MESSAGE_LIMIT=500
DEFAULT_PRO_MESSAGE_LIMIT=30000
DEFAULT_MAX_SENTENCES=5
API_KEY_SECRET=
CENTRAL_BOT_SECRET=
CRON_SECRET=
# Partner provisioning: POST /api/v1/partner/tenants with header x-tenant-provision-secret (disable route if unset)
TENANT_PROVISION_SECRET=

# Optional — Mindbloom company mirror after Platform Admin onboarding. When both are set, SaaS POSTs with retries.
MINDBLOOM_PROVISION_URL=
MINDBLOOM_PROVISION_SECRET=

# Optional: comma-separated hostnames for Next.js dev assets (ngrok / tunnel + Turbopack HMR).
# ALLOWED_DEV_ORIGINS=
